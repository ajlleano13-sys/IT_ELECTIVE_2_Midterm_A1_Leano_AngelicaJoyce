<!-- Project -->
<section id="projects" class="mb-5">

    <h2 class="mb-4">@ViewData["Title"]</h2>

    <div class="row">

        <!-- Project 1 -->
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">

                <img src="@ViewData["P1Image"]"
                     class="card-img-top"
                     alt="Project 1">

                <div class="card-body">

                    <h5 class="card-title">
                        @ViewData["P1Title"]
                    </h5>

                    <p class="card-text">
                        @ViewData["P1Desc"]
                    </p>

                    <p>
                        <strong>Technologies:</strong><br>
                        @ViewData["P1Tech"]
                    </p>

                    <button class="btn btn-primary">
                        @ViewData["Button"]
                    </button>

                </div>

            </div>
        </div>

        <!-- Project 2 -->
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">

                <img src="@ViewData["P2Image"]"
                     class="card-img-top"
                     alt="Project 2">

                <div class="card-body">

                    <h5 class="card-title">
                        @ViewData["P2Title"]
                    </h5>

                    <p class="card-text">
                        @ViewData["P2Desc"]
                    </p>

                    <p>
                        <strong>Technologies:</strong><br>
                        @ViewData["P2Tech"]
                    </p>

                    <button class="btn btn-primary">
                        @ViewData["Button"]
                    </button>

                </div>

            </div>
        </div>

        <!-- Project 3 -->
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">

                <img src="@ViewData["P3Image"]"
                     class="card-img-top"
                     alt="Project 3">

                <div class="card-body">

                    <h5 class="card-title">
                        @ViewData["P3Title"]
                    </h5>

                    <p class="card-text">
                        @ViewData["P3Desc"]
                    </p>

                    <p>
                        <strong>Technologies:</strong><br>
                        @ViewData["P3Tech"]
                    </p>

                    <button class="btn btn-primary">
                        @ViewData["Button"]
                    </button>

                </div>

            </div>
        </div>

    </div>

</section>