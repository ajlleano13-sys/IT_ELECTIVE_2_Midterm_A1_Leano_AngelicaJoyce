<!-- About -->
<section id="about" class="mb-5">

    <h2 class="mb-4">@ViewData["Title"]</h2>

    <div class="card shadow p-4">

        <p>
            I am <strong>@ViewData["Name"]</strong>, a
            <strong>@ViewData["Course"]</strong>.
            @ViewData["Description1"]
        </p>

        <p>
            @ViewData["Description2"]
        </p>

        <h5 class="mt-4">Educational Background</h5>

        <ul>
            <li>@ViewData["Education1"]</li>
            <li>@ViewData["Education2"]</li>
        </ul>

        <h5 class="mt-4">Career Goal</h5>

        <p>
            @ViewData["CareerGoal"]
        </p>

        <h5 class="mt-4">Personal Interests</h5>

        <ul>
            <li>@ViewData["Interest1"]</li>
            <li>@ViewData["Interest2"]</li>
            <li>@ViewData["Interest3"]</li>
            <li>@ViewData["Interest4"]</li>
        </ul>

    </div>

</section>